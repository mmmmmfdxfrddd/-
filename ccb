local polnareffEnabled = false
local polnareffFollow = nil
local polnareffAttack = nil
local polnareffRadius = nil
local polnareffQuest = nil

local function getPolnareff()
    local world = Workspace:FindFirstChild("World")
    if not world then return nil end
    local living = world:FindFirstChild("Living")
    if not living then return nil end
    return living:FindFirstChild("Polnareff")
end

local function getPolnareffUpperTorso()
    local npc = getPolnareff()
    if not npc then return nil end
    return npc:FindFirstChild("UpperTorso")
end

local function getPolnareffHumanoid()
    local npc = getPolnareff()
    if not npc then return nil end
    return npc:FindFirstChildOfClass("Humanoid")
end

local function teleportAbovePolnareff()
    local upperTorso = getPolnareffUpperTorso()
    if not upperTorso then return false end
    local char = lp.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local npcPos = upperTorso.Position
    local abovePos = npcPos + Vector3.new(0, 5, 0)
    hrp.CFrame = CFrame.lookAt(abovePos, npcPos)
    return true
end

local function triggerAttackPolnareff()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local input = remotes:FindFirstChild("Input")
                if input then
                    input:InvokeServer(Enum.UserInputType.MouseButton1, Enum.UserInputState.Begin)
                end
            end
        end
    end)
end

local function setPolnareffHealthZero()
    local humanoid = getPolnareffHumanoid()
    if humanoid then
        pcall(function() humanoid.Health = 0 end)
    end
end

local function startPolnareffAttack()
    if polnareffAttack then return end
    polnareffAttack = task.spawn(function()
        while polnareffEnabled do
            local humanoid = getPolnareffHumanoid()
            if humanoid and humanoid.Health > 0 then
                triggerAttackPolnareff()
                task.wait(0.05)
                setPolnareffHealthZero()
            end
            task.wait(0.2)
        end
        polnareffAttack = nil
    end)
end

local function stopPolnareffAttack()
    if polnareffAttack then
        task.cancel(polnareffAttack)
        polnareffAttack = nil
    end
end

local function startPolnareffFollow()
    if polnareffFollow then return end
    polnareffFollow = RunService.Heartbeat:Connect(function()
        if polnareffEnabled then
            teleportAbovePolnareff()
        end
    end)
end

local function stopPolnareffFollow()
    if polnareffFollow then
        polnareffFollow:Disconnect()
        polnareffFollow = nil
    end
end

local function expandRadius()
    pcall(function()
        sethiddenproperty(lp, "SimulationRadius", 112412400000)
        sethiddenproperty(lp, "MaxSimulationRadius", 112412400000)
    end)
end

local function startPolnareffRadius()
    if polnareffRadius then return end
    polnareffRadius = task.spawn(function()
        while polnareffEnabled do
            expandRadius()
            task.wait(0.5)
        end
        polnareffRadius = nil
    end)
end

local function stopPolnareffRadius()
    if polnareffRadius then
        task.cancel(polnareffRadius)
        polnareffRadius = nil
    end
end

local function triggerQuest()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local quest = remotes:FindFirstChild("Quest")
                if quest then
                    quest:InvokeServer("Response", "admpn")
                    task.wait(0.1)
                    quest:InvokeServer("Start", "admpn")
                end
            end
        end
    end)
end

local function startPolnareffQuest()
    if polnareffQuest then return end
    polnareffQuest = task.spawn(function()
        while polnareffEnabled do
            triggerQuest()
            task.wait(0.5)
        end
        polnareffQuest = nil
    end)
end

local function stopPolnareffQuest()
    if polnareffQuest then
        task.cancel(polnareffQuest)
        polnareffQuest = nil
    end
end

local function startPolnareffAll()
    disablePhysics()
    startPolnareffFollow()
    startPolnareffAttack()
    startPolnareffRadius()
    startPolnareffQuest()
end

local function stopPolnareffAll()
    restorePhysics()
    stopPolnareffFollow()
    stopPolnareffAttack()
    stopPolnareffRadius()
    stopPolnareffQuest()
end

-- ==================== 脚本3：自动洗属性（双模式） ====================
local attrRunning1 = false
local attrRunning2 = false

local abilityBlacklist = {
    "Crazy Diamond",
    "The Hand",
    "Magician's Red",
    "Silver Chariot",
    "Cream",
    "White Snake",
    "Star Platinum Stone Ocean",
    "The Emperor",
    "Sticky Fingers",
    "Stone Free",
    "Killer Queen",
    "Hierophant Green",
    "Aerosmith",
    "Weather Report",
    "Soft And Wet",
    "Echoes Act"
}

local abilityWhitelist = {
    "Jotaro's Star Platinum",
    "The World OVA",
    "Star Platinum OVA",
    "Dio's The World",
    "Anubis"
}

local targetAttributes = {"Legendary", "Critical", "Multiply", "Thief", "Forceful"}

local function getCurrentAbility()
    local data = lp:FindFirstChild("Data")
    if not data then return nil end
    local stats = data:FindFirstChild("Stats")
    if not stats then return nil end
    local ability = stats:FindFirstChild("Ability")
    if ability then
        return ability.Value
    end
    return nil
end

local function checkAbilityBlacklist(ability)
    if not ability then return false end
    for _, black in ipairs(abilityBlacklist) do
        if ability == black then
            return true
        end
    end
    return false
end

local function checkAbilityWhitelist(ability)
    if not ability then return false end
    for _, white in ipairs(abilityWhitelist) do
        if ability == white then
            return true
        end
    end
    return false
end

local function sendItem(itemName)
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local send = remotes:FindFirstChild("Send")
                if send then
                    send:FireServer("Item", itemName)
                end
            end
        end
    end)
end

local function getCurrentAttribute()
    local data = lp:FindFirstChild("Data")
    if not data then return nil end
    local stats = data:FindFirstChild("Stats")
    if not stats then return nil end
    local attr = stats:FindFirstChild("Attribute")
    if attr then
        return attr.Value
    end
    return nil
end

local function checkAttribute(attr)
    if not attr then return false end
    for _, target in ipairs(targetAttributes) do
        if attr == target then return true end
    end
    return false
end

local function startAttrLoop(itemName, btn, light)
    if attrRunning1 or attrRunning2 then
        showNotification("⚠️ 提示", "另一个洗属性开关正在运行", 2)
        return
    end
    attrRunning1 = true
    local originalText = btn.Text
    btn.Text = "开"
    btn.BackgroundColor3 = Color3.fromRGB(0, 120, 80)
    light.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    
    task.spawn(function()
        while attrRunning1 do
            sendItem(itemName)
            
            for i = 5, 1, -1 do
                if not attrRunning1 then break end
                task.wait(1)
            end
            if not attrRunning1 then break end
            
            local ability = getCurrentAbility()
            local attr = getCurrentAttribute()
            
            if ability and checkAbilityWhitelist(ability) and attr and checkAttribute(attr) then
                showNotification("🎯 目标组合", ability .. " + " .. attr .. "，已停止", 3)
                attrRunning1 = false
                btn.Text = originalText
                btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
                light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                attrRunning2 = false
                return
            end
            
            if ability and checkAbilityBlacklist(ability) then
                showNotification("🔄 黑名单替身", ability .. " 在黑名单中，使用Rokakaka", 2)
                sendItem("Rokakaka")
                task.wait(1)
                continue
            end
            
            if attr and checkAttribute(attr) then
                showNotification("🎯 目标属性", "已获得 " .. attr, 3)
                attrRunning1 = false
                btn.Text = originalText
                btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
                light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                attrRunning2 = false
                return
            end
            
            sendItem("Rokakaka")
            task.wait(1)
        end
        btn.Text = originalText
        btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        attrRunning2 = false
    end)
end

local function startAttrLoop2(itemName, btn, light)
    if attrRunning1 or attrRunning2 then
        showNotification("⚠️ 提示", "另一个洗属性开关正在运行", 2)
        return
    end
    attrRunning2 = true
    local originalText = btn.Text
    btn.Text = "开"
    btn.BackgroundColor3 = Color3.fromRGB(0, 120, 80)
    light.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    
    task.spawn(function()
        while attrRunning2 do
            sendItem(itemName)
            
            for i = 5, 1, -1 do
                if not attrRunning2 then break end
                task.wait(1)
            end
            if not attrRunning2 then break end
            
            local ability = getCurrentAbility()
            local attr = getCurrentAttribute()
            
            if ability and checkAbilityWhitelist(ability) and attr and checkAttribute(attr) then
                showNotification("🎯 目标组合", ability .. " + " .. attr .. "，已停止", 3)
                attrRunning2 = false
                btn.Text = originalText
                btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
                light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                attrRunning1 = false
                return
            end
            
            if ability and checkAbilityBlacklist(ability) then
                showNotification("🔄 黑名单替身", ability .. " 在黑名单中，使用Rokakaka", 2)
                sendItem("Rokakaka")
                task.wait(1)
                continue
            end
            
            local attr = getCurrentAttribute()
            if attr and checkAttribute(attr) then
                showNotification("🎯 目标属性", "已获得 " .. attr, 3)
                attrRunning2 = false
                btn.Text = originalText
                btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
                light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                attrRunning1 = false
                return
            end
            
            sendItem("Rokakaka")
            task.wait(1)
        end
        btn.Text = originalText
        btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        attrRunning1 = false
    end)
end

local function stopAttrLoop(btn, light)
    attrRunning1 = false
    attrRunning2 = false
    btn.Text = "关"
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
end

-- ==================== 开关绑定 ====================
toggle1.btn.MouseButton1Click:Connect(function()
    if vanillaEnabled then
        vanillaEnabled = false
        stopVanillaLoop()
        toggle1.btn.Text = "关"
        toggle1.btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        toggle1.light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        restorePhysics()
        showNotification("❌ 刷副本", "已关闭", 2)
    else
        vanillaEnabled = true
        toggle1.btn.Text = "开"
        toggle1.btn.BackgroundColor3 = Color3.fromRGB(0, 150, 80)
        toggle1.light.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        
        disablePhysics()
        
        local char = lp.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = CFrame.new(-679.340, -115.262, -809.080)
            end
        end
        
        task.wait(1)
        
        startVanillaLoop()
        showNotification("✅ 刷副本", "已开启（物理全关）", 2)
    end
end)

