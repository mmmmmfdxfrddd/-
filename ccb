-- ==================== 脚本3：抽面具 ====================
local maskRunning = false
local maskLoop = nil

local function sendMask()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local send = remotes:FindFirstChild("Send")
                if send then
                    send:FireServer("Item", "Kars Mask")
                end
            end
        end
    end)
end

local function startMaskLoop()
    if maskLoop then return end
    maskLoop = task.spawn(function()
        while maskRunning do
            sendMask()
            
            for i = 2, 1, -1 do
                if not maskRunning then break end
                task.wait(1)
            end
            if not maskRunning then break end
            
            local attr = getCurrentAttribute()
            if attr and checkThirdLayerAttribute(attr) then
                showNotification("🎯 目标面具属性", "已获得 " .. attr, 3)
                maskRunning = false
                toggle4.btn.Text = "关"
                toggle4.btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
                toggle4.light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                return
            end
        end
        maskLoop = nil
        toggle4.btn.Text = "关"
        toggle4.btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        toggle4.light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end)
end

local function stopMaskLoop()
    maskRunning = false
    if maskLoop then
        task.cancel(maskLoop)
        maskLoop = nil
    end
    toggle4.btn.Text = "关"
    toggle4.btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    toggle4.light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
end

-- ==================== 脚本4：自动启动替身 ====================
local summonMonitorEnabled = false
local summonMonitorTask = nil

local function findSummonInLocalPlayer()
    local char = lp.Character
    if not char then return nil end
    return char:FindFirstChild("Kars") or char:FindFirstChild("Stand")
end

local function triggerSummonQSkill()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local input = remotes:FindFirstChild("Input")
                if input then
                    input:InvokeServer(Enum.KeyCode.Q, Enum.UserInputState.Begin)
                end
            end
        end
    end)
end

local function startSummonMonitor()
    if summonMonitorTask then return end
    
    summonMonitorTask = task.spawn(function()
        while summonMonitorEnabled do
            local found = findSummonInLocalPlayer()
            
            if not found then
                triggerSummonQSkill()
            end
            
            task.wait(0.5)
        end
        summonMonitorTask = nil
    end)
end

local function stopSummonMonitor()
    summonMonitorEnabled = false
    if summonMonitorTask then
        task.cancel(summonMonitorTask)
        summonMonitorTask = nil
    end
end

