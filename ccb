-- ==================== 脚本1：刷副本(Vanilla) ====================
local vanillaEnabled = false
local vanillaMainLoop = nil
local vanillaFollow = nil
local vanillaAttack = nil
local vanillaStopAttack = false

local function getVanilla()
    local world = Workspace:FindFirstChild("World")
    if not world then return nil end
    local map = world:FindFirstChild("Map")
    if not map then return nil end
    local lairs = map:FindFirstChild("Lairs")
    if not lairs then return nil end
    local model = lairs:FindFirstChild("Model")
    if not model then return nil end
    local alive = model:FindFirstChild("Alive")
    if not alive then return nil end
    return alive:FindFirstChild("Vanilla")
end

local function getVanillaHead()
    local npc = getVanilla()
    if not npc then return nil end
    return npc:FindFirstChild("Head")
end

local function getVanillaHumanoid()
    local npc = getVanilla()
    if not npc then return nil end
    return npc:FindFirstChildOfClass("Humanoid")
end

local function teleportAboveVanilla()
    local head = getVanillaHead()
    if not head then return false end
    local headPos = head.Position
    local abovePos = headPos + Vector3.new(0, 10, 0)
    local char = lp.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = CFrame.lookAt(abovePos, headPos)
    return true
end

local function triggerLair()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local lair = remotes:FindFirstChild("Lair")
                if lair then
                    lair:FireServer("200")
                end
            end
        end
    end)
end

local function triggerAttackVanilla()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local input = remotes:FindFirstChild("Input")
                if input then
                    input:InvokeServer(Enum.UserInputType.MouseButton1, Enum.UserInputState.Begin)
                end
            end
        end
    end)
end

local function waitForVanilla()
    while vanillaEnabled do
        if getVanilla() then return true end
        task.wait(0.25)
    end
    return false
end

local function startVanillaFollow()
    if vanillaFollow then return end
    vanillaFollow = RunService.Heartbeat:Connect(function()
        if not vanillaEnabled then return end
        local humanoid = getVanillaHumanoid()
        if humanoid and humanoid.Health <= 0 then return end
        teleportAboveVanilla()
    end)
end

local function stopVanillaFollow()
    if vanillaFollow then
        vanillaFollow:Disconnect()
        vanillaFollow = nil
    end
end

local function startVanillaAttack()
    if vanillaAttack then return end
    vanillaStopAttack = false
    vanillaAttack = task.spawn(function()
        local waitTime = 5
        while waitTime > 0 and vanillaEnabled and not vanillaStopAttack do
            task.wait(1)
            waitTime = waitTime - 1
        end
        while vanillaEnabled and not vanillaStopAttack do
            local humanoid = getVanillaHumanoid()
            if humanoid and humanoid.Health > 0 then
                triggerAttackVanilla()
                task.wait(0.1)
            else
                break
            end
        end
        vanillaAttack = nil
    end)
end

local function stopVanillaAttack()
    vanillaStopAttack = true
    if vanillaAttack then
        task.cancel(vanillaAttack)
        vanillaAttack = nil
    end
end

local function startVanillaLoop()
    if vanillaMainLoop then return end
    vanillaMainLoop = task.spawn(function()
        while vanillaEnabled do
            triggerLair()
            task.wait(0.25)
            
            if not waitForVanilla() then
                continue
            end
            
            startVanillaFollow()
            startVanillaAttack()
            
            while vanillaEnabled do
                local humanoid = getVanillaHumanoid()
                if not humanoid or humanoid.Health <= 0 then
                    break
                end
                task.wait(0.1)
            end
            
            stopVanillaAttack()
            stopVanillaFollow()
            
            task.wait(1)
            triggerLair()
            task.wait(0.5)
        end
        vanillaMainLoop = nil
    end)
end

local function stopVanillaLoop()
    vanillaEnabled = false
    stopVanillaAttack()
    stopVanillaFollow()
    if vanillaMainLoop then
        task.cancel(vanillaMainLoop)
        vanillaMainLoop = nil
    end
end

