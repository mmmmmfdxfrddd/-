-- ==================== 物理控制 ====================
local savedPhysics = {
    walkSpeed = nil, jumpPower = nil, autoRotate = nil, platformStand = nil,
    velocity = nil, rotationalVelocity = nil, assemblyLinearVelocity = nil, assemblyAngularVelocity = nil,
    hipHeight = nil, maxSlopeAngle = nil, useJumpPower = nil, breakJointsOnDeath = nil, sit = nil
}

local function disablePhysics()
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        savedPhysics.walkSpeed = humanoid.WalkSpeed
        savedPhysics.jumpPower = humanoid.JumpPower
        savedPhysics.autoRotate = humanoid.AutoRotate
        savedPhysics.platformStand = humanoid.PlatformStand
        savedPhysics.hipHeight = humanoid.HipHeight
        savedPhysics.maxSlopeAngle = humanoid.MaxSlopeAngle
        savedPhysics.useJumpPower = humanoid.UseJumpPower
        savedPhysics.breakJointsOnDeath = humanoid.BreakJointsOnDeath
        savedPhysics.sit = humanoid.Sit
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
        humanoid.AutoRotate = false
        humanoid.PlatformStand = true
        humanoid.HipHeight = 0
        humanoid.MaxSlopeAngle = 0
        humanoid.UseJumpPower = false
        humanoid.BreakJointsOnDeath = false
        humanoid.Sit = false
    end
    if hrp then
        savedPhysics.velocity = hrp.Velocity
        savedPhysics.rotationalVelocity = hrp.RotVelocity
        savedPhysics.assemblyLinearVelocity = hrp.AssemblyLinearVelocity
        savedPhysics.assemblyAngularVelocity = hrp.AssemblyAngularVelocity
        hrp.Velocity = Vector3.new(0, 0, 0)
        hrp.RotVelocity = Vector3.new(0, 0, 0)
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end
    for _, part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            pcall(function()
                part.Velocity = Vector3.new(0, 0, 0)
                part.RotVelocity = Vector3.new(0, 0, 0)
                part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            end)
        end
    end
end

local function restorePhysics()
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        if savedPhysics.walkSpeed ~= nil then humanoid.WalkSpeed = savedPhysics.walkSpeed end
        if savedPhysics.jumpPower ~= nil then humanoid.JumpPower = savedPhysics.jumpPower end
        if savedPhysics.autoRotate ~= nil then humanoid.AutoRotate = savedPhysics.autoRotate end
        if savedPhysics.platformStand ~= nil then humanoid.PlatformStand = savedPhysics.platformStand end
        if savedPhysics.hipHeight ~= nil then humanoid.HipHeight = savedPhysics.hipHeight end
        if savedPhysics.maxSlopeAngle ~= nil then humanoid.MaxSlopeAngle = savedPhysics.maxSlopeAngle end
        if savedPhysics.useJumpPower ~= nil then humanoid.UseJumpPower = savedPhysics.useJumpPower end
        if savedPhysics.breakJointsOnDeath ~= nil then humanoid.BreakJointsOnDeath = savedPhysics.breakJointsOnDeath end
        if savedPhysics.sit ~= nil then humanoid.Sit = savedPhysics.sit end
    end
    if hrp then
        if savedPhysics.velocity ~= nil then hrp.Velocity = savedPhysics.velocity end
        if savedPhysics.rotationalVelocity ~= nil then hrp.RotVelocity = savedPhysics.rotationalVelocity end
        if savedPhysics.assemblyLinearVelocity ~= nil then hrp.AssemblyLinearVelocity = savedPhysics.assemblyLinearVelocity end
        if savedPhysics.assemblyAngularVelocity ~= nil then hrp.AssemblyAngularVelocity = savedPhysics.assemblyAngularVelocity end
    end
end

