-- ==================== 脚本1：刷副本(Vanilla) ====================
local vanillaEnabled = false
local vanillaMainLoop = nil
local vanillaFollow = nil
local vanillaAttack = nil
local vanillaStopAttack = false

local function getVanilla()
    local world = Workspace:FindFirstChild("World")
    if not world then return nil end
    local map = world:FindFirstChild("Map")
    if not map then return nil end
    local lairs = map:FindFirstChild("Lairs")
    if not lairs then return nil end
    local model = lairs:FindFirstChild("Model")
    if not model then return nil end
    local alive = model:FindFirstChild("Alive")
    if not alive then return nil end
    return alive:FindFirstChild("Vanilla")
end

local function getVanillaHead()
    local npc = getVanilla()
    if not npc then return nil end
    return npc:FindFirstChild("Head")
end

local function getVanillaHumanoid()
    local npc = getVanilla()
    if not npc then return nil end
    return npc:FindFirstChildOfClass("Humanoid")
end

local function teleportToVanilla()
    local head = getVanillaHead()
    if not head then return false end
    
    local char = lp.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local headPos = head.Position
    local offset = (directionIsUp and 1 or -1) * heightValue
    local targetPos = headPos + Vector3.new(0, offset, 0)
    
    hrp.CFrame = CFrame.lookAt(targetPos, headPos)
    return true
end

local function triggerLair()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local lair = remotes:FindFirstChild("Lair")
                if lair then
                    lair:FireServer("200")
                end
            end
        end
    end)
end

local function triggerAttackVanilla()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local input = remotes:FindFirstChild("Input")
                if input then
                    input:InvokeServer(Enum.UserInputType.MouseButton1, Enum.UserInputState.Begin)
                end
            end
        end
    end)
end

local function waitForVanillaWithRetry()
    local maxAttempts = 20
    local attempts = 0
    
    while vanillaEnabled and attempts < maxAttempts do
        if getVanilla() then
            return true
        end
        attempts = attempts + 1
        task.wait(0.25)
    end
    
    if vanillaEnabled then
        local char = lp.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = CFrame.new(-679.340, -115.262, -809.080)
            end
        end
        
        task.wait(1)
        
        triggerLair()
        task.wait(0.25)
        
        attempts = 0
        while vanillaEnabled and attempts < maxAttempts do
            if getVanilla() then
                return true
            end
            attempts = attempts + 1
            task.wait(0.25)
        end
    end
    
    return false
end

local function startVanillaFollow()
    if vanillaFollow then return end
    vanillaFollow = RunService.Heartbeat:Connect(function()
        if not vanillaEnabled then return end
        local humanoid = getVanillaHumanoid()
        if humanoid and humanoid.Health <= 0 then return end
        teleportToVanilla()
    end)
end

local function stopVanillaFollow()
    if vanillaFollow then
        vanillaFollow:Disconnect()
        vanillaFollow = nil
    end
end

local function startVanillaAttack()
    if vanillaAttack then return end
    vanillaStopAttack = false
    vanillaAttack = task.spawn(function()
        while vanillaEnabled and not vanillaStopAttack do
            local humanoid = getVanillaHumanoid()
            if humanoid and humanoid.Health > 0 then
                triggerAttackVanilla()
                task.wait(0.025)
            else
                break
            end
        end
        vanillaAttack = nil
    end)
end

local function stopVanillaAttack()
    vanillaStopAttack = true
    if vanillaAttack then
        task.cancel(vanillaAttack)
        vanillaAttack = nil
    end
end

local function startVanillaLoop()
    if vanillaMainLoop then return end
    vanillaMainLoop = task.spawn(function()
        while vanillaEnabled do
            triggerLair()
            task.wait(0.25)
            
            if not waitForVanillaWithRetry() then
                task.wait(0.5)
                continue
            end
            
            startVanillaFollow()
            startVanillaAttack()
            
            while vanillaEnabled do
                local humanoid = getVanillaHumanoid()
                if not humanoid or humanoid.Health <= 0 then
                    break
                end
                task.wait(0.1)
            end
            
            stopVanillaAttack()
            stopVanillaFollow()
            
            task.wait(1)
            triggerLair()
            task.wait(0.5)
        end
        vanillaMainLoop = nil
    end)
end

local function stopVanillaLoop()
    vanillaEnabled = false
    stopVanillaAttack()
    stopVanillaFollow()
    if vanillaMainLoop then
        task.cancel(vanillaMainLoop)
        vanillaMainLoop = nil
    end
end

-- ==================== 脚本2：自动洗属性 ====================
local attrRunning1 = false
local attrRunning2 = false

local abilityBlacklist = {
    "Crazy Diamond", "The Hand", "Magician's Red", "Silver Chariot",
    "Cream", "White Snake", "Star Platinum Stone Ocean", "The Emperor",
    "Sticky Fingers", "Stone Free", "Killer Queen", "Hierophant Green",
    "Aerosmith", "Weather Report", "Soft And Wet", "Echoes Act"
}

local abilityWhitelist = {
    "Jotaro's Star Platinum", "The World OVA", "Star Platinum OVA",
    "Dio's The World", "Anubis"
}

local firstLayerAttributes = {"Legendary", "Critical", "Multiply", "Thief", "Forceful"}
local thirdLayerAttributes = {"Forceful", "Legendary"}

local function getCurrentAbility()
    local data = lp:FindFirstChild("Data")
    if not data then return nil end
    local stats = data:FindFirstChild("Stats")
    if not stats then return nil end
    local ability = stats:FindFirstChild("Ability")
    if ability then return ability.Value end
    return nil
end

local function getCurrentAttribute()
    local data = lp:FindFirstChild("Data")
    if not data then return nil end
    local stats = data:FindFirstChild("Stats")
    if not stats then return nil end
    local attr = stats:FindFirstChild("Attribute")
    if attr then return attr.Value end
    return nil
end

local function checkAbilityBlacklist(ability)
    if not ability then return false end
    for _, black in ipairs(abilityBlacklist) do
        if ability == black then return true end
    end
    return false
end

local function checkAbilityWhitelist(ability)
    if not ability then return false end
    for _, white in ipairs(abilityWhitelist) do
        if ability == white then return true end
    end
    return false
end

local function checkFirstLayerAttribute(attr)
    if not attr then return false end
    for _, target in ipairs(firstLayerAttributes) do
        if attr == target then return true end
    end
    return false
end

local function checkThirdLayerAttribute(attr)
    if not attr then return false end
    for _, target in ipairs(thirdLayerAttributes) do
        if attr == target then return true end
    end
    return false
end

local function sendItem(itemName)
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Library")
        if remotes then
            remotes = remotes:FindFirstChild("Remotes")
            if remotes then
                local send = remotes:FindFirstChild("Send")
                if send then
                    send:FireServer("Item", itemName)
                end
            end
        end
    end)
end

local function checkAttributeResult()
    local ability = getCurrentAbility()
    local attr = getCurrentAttribute()
    
    if ability and checkAbilityWhitelist(ability) and attr and checkFirstLayerAttribute(attr) then
        showNotification("🎯 完美匹配(第1层)", ability .. " + " .. attr .. "，已停止", 4)
        return "perfect"
    end
    
    if ability and checkAbilityBlacklist(ability) then
        showNotification("🔄 黑名单替身(第2层)", ability .. "，使用Rokakaka跳过", 2)
        sendItem("Rokakaka")
        task.wait(1)
        return "reroll"
    end
    
    if attr and checkThirdLayerAttribute(attr) then
        showNotification("🎯 兜底保留(第3层)", "属性: " .. attr .. "，已停止", 3)
        return "keep"
    end
    
    showNotification("🔄 不满足条件", "当前: " .. (ability or "?") .. " / " .. (attr or "?"), 1)
    sendItem("Rokakaka")
    task.wait(1)
    return "continue"
end

local function startAttrLoop(itemName, btn, light)
    if attrRunning1 or attrRunning2 then
        showNotification("⚠️ 提示", "另一个洗属性开关正在运行", 2)
        return
    end
    attrRunning1 = true
    btn.Text = "开"
    btn.BackgroundColor3 = Color3.fromRGB(0, 120, 80)
    light.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    
    task.spawn(function()
        while attrRunning1 do
            sendItem(itemName)
            for i = 5, 1, -1 do
                if not attrRunning1 then break end
                task.wait(1)
            end
            if not attrRunning1 then break end
            
            local result = checkAttributeResult()
            if result == "perfect" or result == "keep" then
                attrRunning1 = false
                attrRunning2 = false
                btn.Text = "关"
                btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
                light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                return
            end
        end
        btn.Text = "关"
        btn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        light.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        attrRunning1 = false
        attrRunning2 = false
    end)
end

